---
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "@/lib/types";

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalUrl?: string;
}

const {
	title,
	description = siteConfig.description,
	image,
	canonicalUrl,
} = Astro.props;

const fullTitle =
	title === siteConfig.name ? title : `${title} · ${siteConfig.name}`;
const resolvedUrl = canonicalUrl || Astro.url.href;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#0a84ff" />
<ClientRouter />

<!-- 预加载：关键字体（在首屏即需要显示） -->
<link rel="preload" href="https://ffaff.fun/fonts/lora-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="https://ffaff.fun/fonts/lxgw-wenkai-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

<!-- DNS 预解析：外部资源域名 -->
<link rel="dns-prefetch" href="https://typora-piclists.oss-cn-shenzhen.aliyuncs.com" />
<link rel="dns-prefetch" href="https://challenges.cloudflare.com" />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedUrl} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap.xml" />
<link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href="/rss.xml" />
<link rel="webmention" href="/api/webmention" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={resolvedUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={image} />}

<!-- Twitter -->
<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{image && <meta name="twitter:image" content={image} />}
