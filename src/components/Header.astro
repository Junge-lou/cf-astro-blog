---
import { siteConfig } from "@/lib/types";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<div class="site-header-shell">
		<div class="site-header-surface" aria-hidden="true"></div>
		<nav class="site-nav-content" transition:persist>
			<a href="/" class="site-brand" aria-label={siteConfig.name}>
				<span class="site-brand-mark">E</span>
				<span class="site-brand-copy">
					<strong>{siteConfig.name}</strong>
					<small>流畅、克制、持续更新的技术写作</small>
				</span>
			</a>
			<ul class="nav-links">
				<li>
					<a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>首页</a>
				</li>
				<li>
					<a href="/blog" class:list={["nav-link", { active: currentPath.startsWith("/blog") }]}>归档</a>
				</li>
				<li>
					<a href="/search" class:list={["nav-link", { active: currentPath === "/search" }]}>搜索</a>
				</li>
			</ul>
			<div class="nav-actions">
				<ThemeToggle />
			</div>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		pointer-events: none;
		transition:
			top 360ms cubic-bezier(0.22, 1, 0.36, 1),
			padding-top 360ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.site-header-shell {
		position: relative;
		padding-top: 0;
		pointer-events: auto;
	}

	.site-header-surface {
		position: absolute;
		inset: 0 0 auto;
		left: 50%;
		width: 100vw;
		height: 100%;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.16);
		box-shadow: 0 10px 24px -26px rgba(8, 18, 34, 0.18);
		transform: translate3d(-50%, 0, 0) scaleX(1);
		transform-origin: center top;
		will-change: transform, border-radius, background-color, box-shadow;
		transition:
			transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
			border-radius 360ms cubic-bezier(0.22, 1, 0.36, 1),
			border-color 360ms cubic-bezier(0.22, 1, 0.36, 1),
			background-color 360ms cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 360ms cubic-bezier(0.22, 1, 0.36, 1),
			backdrop-filter 360ms cubic-bezier(0.22, 1, 0.36, 1),
			-webkit-backdrop-filter 360ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.site-nav-content {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		width: min(calc(100% - 2rem), calc(var(--max-width) + 2rem));
		margin-inline: auto;
		padding:
			0.9rem
			calc(1.4rem + env(safe-area-inset-right))
			1rem
			calc(1.4rem + env(safe-area-inset-left));
		transition:
			width 360ms cubic-bezier(0.22, 1, 0.36, 1),
			padding 360ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
	}

	.site-brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: var(--radius-inner);
		background: #0a84ff;
		color: #ffffff;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 12px 30px -24px rgba(10, 132, 255, 0.4);
	}

	.site-brand-copy {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.site-brand-copy strong {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
		letter-spacing: -0.02em;
	}

	.site-brand-copy small {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		white-space: nowrap;
	}

	.nav-links,
	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-md);
		list-style: none;
	}

	.nav-link {
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		background: transparent;
		transition:
			color var(--transition),
			background-color var(--transition),
			border-color var(--transition),
			transform var(--transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-accent);
		background: rgba(10, 132, 255, 0.08);
		border-color: rgba(10, 132, 255, 0.12);
	}

	.nav-link:hover,
	.nav-link.active {
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .site-header {
		top: 0;
		padding-top: 0.85rem;
	}

	:global(html[data-nav-condensed]) .site-header-shell {
		padding-inline: 0.5rem;
	}

	:global(html[data-nav-condensed]) .site-header-surface {
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: var(--radius-panel);
		background: rgba(255, 255, 255, 0.12);
		box-shadow: 0 18px 36px -30px rgba(8, 18, 34, 0.22);
		backdrop-filter: blur(16px) saturate(130%);
		-webkit-backdrop-filter: blur(16px) saturate(130%);
		transform: translate3d(-50%, 0, 0) scaleX(var(--nav-condensed-scale, 0.82));
	}

	:global(html[data-nav-condensed]) .site-nav-content {
		width: min(calc(100% - 1rem), var(--max-width));
		padding: 0.72rem 0.92rem;
	}

	@media (max-width: 960px) {
		.site-header {
			top: 0;
			padding-top: 0;
		}

		.site-nav-content {
			flex-wrap: wrap;
			justify-content: center;
			width: min(calc(100% - 1.2rem), calc(var(--max-width) + 1rem));
			padding:
				0.82rem
				calc(0.9rem + env(safe-area-inset-right))
				0.95rem
				calc(0.9rem + env(safe-area-inset-left));
		}

		.site-brand {
			width: 100%;
			justify-content: center;
		}

		.site-brand-copy {
			justify-items: center;
		}

		.site-brand-copy small {
			white-space: normal;
			text-align: center;
		}

		.nav-links {
			order: 2;
			justify-content: center;
			flex-wrap: wrap;
		}

		.nav-actions {
			order: 3;
		}

		:global(html[data-nav-condensed]) .site-header {
			padding-top: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-header-shell {
			padding-inline: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-nav-content {
			width: min(calc(100% - 1rem), var(--max-width));
			padding: 0.78rem 0.88rem;
		}
	}

	@media (max-width: 640px) {
		.site-nav-content {
			padding: 0.8rem;
		}

		.nav-links,
		.nav-actions {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.nav-link {
			padding-inline: 0.88rem;
		}

		:global(html[data-nav-condensed]) .site-header-surface {
			border-radius: 24px;
		}
	}
</style>
