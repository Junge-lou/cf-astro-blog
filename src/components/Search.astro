---
interface TaxonomyOption {
	slug: string;
	name: string;
}

interface Props {
	initialQuery?: string;
	categories?: TaxonomyOption[];
	tags?: TaxonomyOption[];
	selectedCategory?: string;
	selectedTags?: string[];
}

const {
	initialQuery = "",
	categories = [],
	tags = [],
	selectedCategory = "",
	selectedTags = [],
}: Props = Astro.props;

const selectedTagSet = new Set(selectedTags);
---

<div class="search-container">
	<form class="search-form" action="/search" method="get">
		<input
			type="search"
			name="q"
			class="search-input"
			placeholder="搜索文章标题、摘要或关键词"
			aria-label="搜索文章"
			autocomplete="off"
			value={initialQuery}
		/>
		{categories.length > 0 ? (
			<select name="category" class="search-select" aria-label="按分类筛选">
				<option value="">全部分类</option>
				{categories.map((category) => (
					<option value={category.slug} selected={selectedCategory === category.slug}>
						{category.name}
					</option>
				))}
			</select>
		) : null}
		<button type="submit" class="button search-button">开始搜索</button>

		{tags.length > 0 ? (
			<fieldset class="search-tags">
				<legend>按标签筛选</legend>
				<div class="search-tag-list">
					{tags.map((tag) => (
						<label class="search-tag-chip">
							<input
								type="checkbox"
								name="tags"
								value={tag.slug}
								checked={selectedTagSet.has(tag.slug)}
							/>
							<span>{tag.name}</span>
						</label>
					))}
				</div>
			</fieldset>
		) : null}
	</form>
	<div id="search-results" class="search-results"></div>
</div>

<style>
	.search-container {
		width: 100%;
		max-width: 46rem;
	}

	.search-form {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0.7rem;
		border-radius: var(--radius-card);
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(12px) saturate(120%);
		-webkit-backdrop-filter: blur(12px) saturate(120%);
	}

	.search-input,
	.search-select {
		flex: 1;
		min-width: min(100%, 12rem);
		padding: 0.95rem 1rem;
		border: 1px solid transparent;
		border-radius: var(--radius-pill);
		background-color: transparent;
		color: var(--color-text);
		font-size: var(--font-size-base);
		font-family: var(--font-sans);
		transition:
			border-color var(--transition),
			background-color var(--transition);
	}

	.search-select {
		appearance: none;
	}

	.search-input::placeholder {
		color: var(--color-text-muted);
	}

	.search-input:focus,
	.search-select:focus {
		outline: none;
		border-color: rgba(10, 132, 255, 0.22);
		background: var(--color-bg-tertiary);
	}

	.search-button {
		padding: 0.95rem 1.2rem;
	}

	.search-tags {
		width: 100%;
		border: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.55rem;
	}

	.search-tags legend {
		font-size: 0.82rem;
		color: var(--color-text-muted);
	}

	.search-tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.search-tag-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.62rem;
		border-radius: var(--radius-pill);
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.06);
		font-size: 0.8rem;
		color: var(--color-text);
		cursor: pointer;
	}

	.search-tag-chip input {
		margin: 0;
	}

	.search-results {
		margin-top: var(--space-md);
	}

	@media (max-width: 640px) {
		.search-form {
			flex-direction: column;
		}

		.search-button {
			width: 100%;
		}
	}
</style>
