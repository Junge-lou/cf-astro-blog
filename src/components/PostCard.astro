---
import { formatDate } from "@/lib/format";
import { siteConfig } from "@/lib/types";

interface Props {
	title: string;
	slug: string;
	excerpt?: string | null;
	publishedAt?: string | null;
	categoryName?: string | null;
	authorName?: string | null;
}

const { title, slug, excerpt, publishedAt, categoryName, authorName } =
	Astro.props;

const formattedDate = publishedAt ? formatDate(publishedAt) : null;
---

<article class="post-card glass-panel" transition:name={`card-${slug}`}>
	<div class="post-card-top">
		<div class="pill-row" transition:name={`meta-${slug}`}>
			{formattedDate && <time class="pill" datetime={publishedAt ?? undefined}>{formattedDate}</time>}
			{categoryName && <span class="pill">{categoryName}</span>}
		</div>
		<a href={`/blog/${slug}`} class="post-card-link">
			<h2 class="post-card-title" transition:name={`title-${slug}`}>{title}</h2>
		</a>
	</div>
	{excerpt && (
		<p class="post-card-excerpt" transition:name={`summary-${slug}`}>
			{excerpt}
		</p>
	)}
	<div class="post-card-meta">
		<span>{authorName || siteConfig.author}</span>
		<a href={`/blog/${slug}`} class="post-card-readmore">继续阅读</a>
	</div>
</article>

<style>
	.post-card {
		display: grid;
		gap: var(--space-md);
		padding: clamp(1.2rem, 1rem + 1vw, 1.8rem);
		transition:
			transform var(--transition),
			border-color var(--transition),
			box-shadow var(--transition),
			background-color var(--transition);
	}

	.post-card:hover {
		transform: translateY(-3px);
		border-color: rgba(10, 132, 255, 0.12);
		box-shadow: 0 22px 40px -34px rgba(8, 18, 34, 0.2);
	}

	.post-card-top {
		display: grid;
		gap: var(--space-md);
	}

	.post-card-link {
		color: inherit;
	}

	.post-card-title {
		font-size: clamp(1.32rem, 1.2rem + 0.55vw, 1.75rem);
		color: var(--color-text);
		line-height: 1.14;
		letter-spacing: -0.03em;
	}

	.post-card-link:hover .post-card-title {
		color: var(--color-accent-hover);
	}

	.post-card-excerpt {
		color: var(--color-text-secondary);
		font-size: 0.98rem;
		line-height: 1.8;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		font-size: 0.88rem;
		color: var(--color-text-muted);
	}

	.post-card-readmore {
		color: var(--color-accent);
		font-weight: 600;
	}

	@media (max-width: 640px) {
		.post-card-meta {
			flex-wrap: wrap;
		}
	}
</style>
