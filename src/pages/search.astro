---
import { and, desc, eq, inArray } from "drizzle-orm";
import PostCard from "@/components/PostCard.astro";
import SearchBox from "@/components/Search.astro";
import { blogCategories, blogPosts, blogPostTags, blogTags } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import {
	getPublicPostKeywordCondition,
	getPublicPostVisibilityCondition,
} from "@/lib/public-content";
import { sanitizeSlug } from "@/lib/security";

const query = Astro.url.searchParams.get("q")?.trim() || "";
const rawSelectedCategory =
	Astro.url.searchParams.get("category")?.trim().toLowerCase() || "";
const selectedCategory = sanitizeSlug(rawSelectedCategory) || "";
const selectedTags = [
	...new Set(
		Astro.url.searchParams
			.getAll("tags")
			.map((item) => sanitizeSlug(item))
			.filter((item): item is string => Boolean(item)),
	),
];
const hasSearchCriteria = Boolean(
	query || selectedCategory || selectedTags.length > 0,
);

let results: Array<{
	title: string;
	slug: string;
	excerpt: string | null;
	publishedAt: string | null;
	authorName: string | null;
	categoryName: string | null;
	featuredImageKey: string | null;
	featuredImageAlt: string | null;
}> = [];

let categories: Array<{ slug: string; name: string }> = [];
let tags: Array<{ slug: string; name: string }> = [];

try {
	const { env } = Astro.locals.runtime;
	const db = getDb(env.DB);
	const [allCategories, allTags] = await Promise.all([
		db
			.select({ slug: blogCategories.slug, name: blogCategories.name })
			.from(blogCategories)
			.orderBy(blogCategories.name),
		db
			.select({ slug: blogTags.slug, name: blogTags.name })
			.from(blogTags)
			.orderBy(blogTags.name),
	]);

	categories = allCategories;
	tags = allTags;

	if (hasSearchCriteria) {
		const whereConditions = [getPublicPostVisibilityCondition()];
		if (query) {
			whereConditions.push(getPublicPostKeywordCondition(`%${query}%`));
		}
		if (selectedCategory) {
			whereConditions.push(eq(blogCategories.slug, selectedCategory));
		}
		if (selectedTags.length > 0) {
			whereConditions.push(inArray(blogTags.slug, selectedTags));
		}

		results = await db
			.select({
				title: blogPosts.title,
				slug: blogPosts.slug,
				excerpt: blogPosts.excerpt,
				publishedAt: blogPosts.publishedAt,
				authorName: blogPosts.authorName,
				categoryName: blogCategories.name,
				featuredImageKey: blogPosts.featuredImageKey,
				featuredImageAlt: blogPosts.featuredImageAlt,
			})
			.from(blogPosts)
			.leftJoin(blogCategories, eq(blogPosts.categoryId, blogCategories.id))
			.leftJoin(blogPostTags, eq(blogPostTags.postId, blogPosts.id))
			.leftJoin(blogTags, eq(blogTags.id, blogPostTags.tagId))
			.where(and(...whereConditions))
			.groupBy(
				blogPosts.id,
				blogPosts.title,
				blogPosts.slug,
				blogPosts.excerpt,
				blogPosts.publishedAt,
				blogPosts.authorName,
				blogCategories.name,
				blogPosts.featuredImageKey,
				blogPosts.featuredImageAlt,
			)
			.orderBy(desc(blogPosts.publishedAt), desc(blogPosts.createdAt))
			.limit(20);
	}
} catch {
	// D1 未绑定时回退为空结果
}

const activeFilters = [
	query ? `关键词：${query}` : "",
	selectedCategory ? `分类：${selectedCategory}` : "",
	selectedTags.length > 0 ? `标签：${selectedTags.join("、")}` : "",
].filter(Boolean);
---

<Base title="搜索" description="按关键词、分类和标签组合检索文章">
	<section
		class="search-hero search-hero-depth glass-panel"
		data-tilt-card
		data-tilt-scale="0.42"
		data-tilt-shift-scale="0.72"
	>
		<span class="section-kicker">站内检索</span>
		<h1 class="page-title">搜索</h1>
		<p class="page-intro">支持关键词、分类与标签组合筛选，快速定位目标内容。</p>
		<div class="search-entry-stage" transition:name="search-entry">
			<SearchBox
				initialQuery={query}
				categories={categories}
				tags={tags}
				selectedCategory={selectedCategory}
				selectedTags={selectedTags}
			/>
		</div>
	</section>

	{hasSearchCriteria ? (
		<section class="search-results-block">
			<div class="section-head">
				<div>
					<h2 class="section-heading">搜索结果</h2>
					<p class="section-subheading">{activeFilters.length > 0 ? activeFilters.join(" · ") : "已启用筛选"}</p>
				</div>
				<p class="results-summary">
					{results.length > 0
						? `共找到 ${results.length} 篇相关文章`
						: "没有找到符合当前条件的内容"}
				</p>
			</div>

			{results.length > 0 ? (
				<div class="search-grid">
					{results.map((post, index) => (
						<PostCard
							title={post.title}
							slug={post.slug}
							excerpt={post.excerpt}
							publishedAt={post.publishedAt}
							authorName={post.authorName}
							categoryName={post.categoryName}
							featuredImageKey={post.featuredImageKey}
							featuredImageAlt={post.featuredImageAlt}
							coverSide={index % 2 === 0 ? "left" : "right"}
						/>
					))}
				</div>
			) : (
				<div class="empty-state glass-panel">
					<p>换一个关键词，或调整分类/标签筛选条件后再试。</p>
				</div>
			)}
		</section>
	) : null}
</Base>

<style>
	.search-hero {
		--glass-panel-opacity: calc(var(--hero-card-opacity, 14) / 100);
		--glass-panel-blur: var(--hero-card-blur, 18px);
		display: grid;
		gap: 1rem;
		padding: clamp(1.5rem, 1rem + 2vw, 2.6rem);
	}

	.search-hero-depth {
		position: relative;
		overflow: hidden;
		transform:
			perspective(1200px)
			rotateX(var(--tilt-rotate-x, 0deg))
			rotateY(var(--tilt-rotate-y, 0deg))
			scale3d(1.002, 1.002, 1.002);
		transform-style: preserve-3d;
		transition:
			transform var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface);
	}

	.search-hero-depth::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background:
			radial-gradient(
				circle at 18% 24%,
				rgba(10, 132, 255, 0.22),
				transparent 38%
			),
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.16),
				rgba(255, 255, 255, 0.02) 58%,
				transparent
			);
		opacity: 0.72;
		pointer-events: none;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * -8px),
			calc(var(--tilt-shift-y, 0) * -8px),
			0
		);
		transition: transform var(--nav-motion-surface);
	}

	.search-hero-depth .section-kicker,
	.search-hero-depth .page-title,
	.search-hero-depth .page-intro {
		position: relative;
		z-index: 1;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 2px),
			calc(var(--tilt-shift-y, 0) * 2px),
			14px
		);
		transition: transform var(--nav-motion-surface);
	}

	.search-results-block {
		display: grid;
		gap: 1.2rem;
	}

	.search-entry-stage {
		width: 100%;
	}

	.search-hero-depth .search-entry-stage {
		position: relative;
		z-index: 1;
		transform: translate3d(
			calc(var(--tilt-shift-x, 0) * 4px),
			calc(var(--tilt-shift-y, 0) * 4px),
			24px
		);
		transition: transform var(--nav-motion-surface);
	}

	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.results-summary {
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.search-grid {
		display: grid;
		gap: 1.2rem;
	}

	@media (max-width: 840px) {
		.section-head {
			flex-direction: column;
			align-items: start;
		}
	}

	@media (hover: none), (pointer: coarse) {
		.search-hero-depth,
		.search-hero-depth::before,
		.search-hero-depth .section-kicker,
		.search-hero-depth .page-title,
		.search-hero-depth .page-intro,
		.search-hero-depth .search-entry-stage {
			transform: none;
		}
	}
</style>
