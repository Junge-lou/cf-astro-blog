---
import { desc, eq } from "drizzle-orm";
import PostCard from "@/components/PostCard.astro";
import SearchBox from "@/components/Search.astro";
import { blogCategories, blogPosts } from "@/db/schema";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { getPublicPostSearchCondition } from "@/lib/public-content";

const query = Astro.url.searchParams.get("q")?.trim() || "";

let results: Array<{
	title: string;
	slug: string;
	excerpt: string | null;
	publishedAt: string | null;
	authorName: string | null;
	categoryName: string | null;
}> = [];

if (query) {
	try {
		const { env } = Astro.locals.runtime;
		const db = getDb(env.DB);
		const pattern = `%${query}%`;

		results = await db
			.select({
				title: blogPosts.title,
				slug: blogPosts.slug,
				excerpt: blogPosts.excerpt,
				publishedAt: blogPosts.publishedAt,
				authorName: blogPosts.authorName,
				categoryName: blogCategories.name,
			})
			.from(blogPosts)
			.leftJoin(blogCategories, eq(blogPosts.categoryId, blogCategories.id))
			.where(getPublicPostSearchCondition(pattern))
			.orderBy(desc(blogPosts.publishedAt))
			.limit(20);
	} catch {
		// D1 未绑定时回退为空结果
	}
}
---

<Base title="搜索" description="按标题、摘要或关键词检索文章">
	<section class="search-hero glass-panel">
		<span class="section-kicker">站内检索</span>
		<h1 class="page-title">搜索</h1>
		<p class="page-intro">
			如果你已经记得一个关键词，直接从这里跳到对应文章会比翻归档更快。
		</p>
		<SearchBox />
	</section>

	{query ? (
		<section class="search-results-block">
			<div class="section-head">
				<div>
					<h2 class="section-heading">搜索结果</h2>
					<p class="section-subheading">关键词：{query}</p>
				</div>
				<p class="results-summary">
					{results.length > 0
						? `共找到 ${results.length} 篇相关文章`
						: `没有找到与“${query}”相关的内容`}
				</p>
			</div>

			{results.length > 0 ? (
				<div class="search-grid">
					{results.map((post) => (
						<PostCard
							title={post.title}
							slug={post.slug}
							excerpt={post.excerpt}
							publishedAt={post.publishedAt}
							authorName={post.authorName}
							categoryName={post.categoryName}
						/>
					))}
				</div>
			) : (
				<div class="empty-state glass-panel">
					<p>换一个更具体的词，或者直接去归档页浏览最近更新。</p>
				</div>
			)}
		</section>
	) : (
		<div class="empty-state glass-panel">
			<p>输入关键词后，这里会显示相关文章结果。</p>
		</div>
	)}
</Base>

<style>
	.search-hero {
		display: grid;
		gap: 1rem;
		padding: clamp(1.5rem, 1rem + 2vw, 2.6rem);
	}

	.search-results-block {
		display: grid;
		gap: 1.2rem;
	}

	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
	}

	.results-summary {
		color: var(--color-text-muted);
		font-size: 0.92rem;
	}

	.search-grid {
		display: grid;
		gap: 1.2rem;
	}

	@media (max-width: 840px) {
		.section-head {
			flex-direction: column;
			align-items: start;
		}
	}
</style>
