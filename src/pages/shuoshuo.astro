---
import { env } from "cloudflare:workers";
import { desc, eq } from "drizzle-orm";
import Base from "@/layouts/Base.astro";
import { getDb } from "@/lib/db";
import { formatDate } from "@/lib/format";
import { shuoshuoPosts } from "@/db/schema";

interface ShuoshuoRow {
	content: string;
	createdAt: string;
}

let shuoshuoList: ShuoshuoRow[] = [];

try {
	const db = getDb(env.DB);
	shuoshuoList = await db
		.select({ content: shuoshuoPosts.content, createdAt: shuoshuoPosts.createdAt })
		.from(shuoshuoPosts)
		.where(eq(shuoshuoPosts.status, "published"))
		.orderBy(desc(shuoshuoPosts.createdAt))
		.limit(20);
} catch {
	// D1 未绑定时保持空列表
}
---

<Base title="说说" description="日常说说，轻量记录生活与想法。">
	<section class="shuoshuo-hero glass-panel">
		<div class="shuoshuo-hero-copy">
			<span class="section-kicker">日常记录</span>
			<h1 class="page-title">说说</h1>
			<p class="page-intro">
				这里展示最近的日常说说，适合用来记录短句、灵感和生活瞬间。
			</p>
		</div>
	</section>

	{shuoshuoList.length > 0 ? (
		<div class="shuoshuo-grid">
			{shuoshuoList.map((item) => (
				<article class="shuoshuo-card glass-panel">
					<p class="shuoshuo-card-content">{item.content}</p>
					<time class="shuoshuo-card-time">{formatDate(item.createdAt)}</time>
				</article>
			))}
		</div>
	) : (
		<div class="empty-state glass-panel">
			<p>还没有说说内容。你可以先登录后台发布第一条日常更新。</p>
		</div>
	)}
</Base>

<style>
	.shuoshuo-hero {
		padding: clamp(1.5rem, 1rem + 2vw, 2.2rem);
		display: grid;
		gap: 1rem;
	}

	.shuoshuo-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-inline: 0.5rem;
	}

	.shuoshuo-card {
		position: relative;
		display: inline-flex;
		flex-direction: column;
		gap: 0.85rem;
		max-width: clamp(20rem, 45vw, 42rem);
		width: fit-content;
		padding: 1.15rem 1.4rem;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.85);
		border-radius: 1.75rem 1.75rem 1.75rem 0.8rem;
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
		backdrop-filter: blur(16px);
	}

	.shuoshuo-card::after {
		content: "";
		position: absolute;
		bottom: 0.85rem;
		left: 1rem;
		width: 1rem;
		height: 1rem;
		background: inherit;
		border-bottom-right-radius: 0.2rem;
		transform: translateY(50%) rotate(45deg);
		z-index: -1;
	}

	.shuoshuo-card:nth-child(even) {
		align-self: flex-end;
		border-radius: 1.75rem 1.75rem 0.8rem 1.75rem;
		background: rgba(232, 244, 255, 0.96);
	}

	.shuoshuo-card:nth-child(even)::after {
		left: auto;
		right: 1rem;
	}

	.shuoshuo-card-content {
		white-space: pre-wrap;
		line-height: 1.9;
		color: var(--text-secondary, #2f3c4f);
		font-size: 1rem;
	}

	.shuoshuo-card-time {
		font-size: 0.9rem;
		color: var(--text-muted, #697381);
		margin-top: 0.25rem;
		align-self: flex-end;
	}

	@media (max-width: 720px) {
		.shuoshuo-card {
			width: 100%;
			max-width: 100%;
			padding: 1rem 1.1rem;
		}

		.shuoshuo-card::after {
			left: 1rem;
			right: auto;
		}

		.shuoshuo-card:nth-child(even) {
			align-self: stretch;
			border-radius: 1.75rem;
		}

		.shuoshuo-card:nth-child(even)::after {
			right: auto;
		}
	}
</style>
